    "/api/tiktok/video/transcript": {
      "get": {
        "operationId": "getApiTiktokVideoTranscript",
        "tags": ["Video"],
        "summary": "Get video transcript",
        "description": "Obtain the transcript of a TikTok video. Supports AI fallback for videos without native captions.",
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "TikTok video URL"
          },
          {
            "name": "language",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Language code (e.g. en, es, fr)"
          },
          {
            "name": "use_ai_as_fallback",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Set to true to use AI transcription when native captions are unavailable"
          }
        ],
        "responses": {
          "200": { "description": "Video transcript with timestamps" },
