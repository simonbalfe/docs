          },
          {
            "name": "trim",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean" },
            "description": "Set to true to get a trimmed response"
          }
        ],
        "responses": {
          "200": { "description": "Following list with pagination cursor" },
