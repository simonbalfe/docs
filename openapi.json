          "502": { "description": "Upstream API error — TikTok returned an error, retry the request" }
        }
      }
    },
    "/api/tiktok/user/live": {
      "get": {
        "operationId": "getApiTiktokUserLive",
        "tags": ["Profile"],
        "summary": "Get user live stream",
        "description": "Retrieve live stream data for a TikTok user including stream URLs and viewer counts.",
        "parameters": [
          {
            "name": "handle",
            "in": "query",
