{
  "openapi": "3.1.0",
  "info": {
    "title": "CreatorCrawl API",
    "description": "Scrape TikTok data at scale. Profiles, videos, comments, followers, trending content, and more.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://creatorcrawl.com",
      "description": "Production"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key from your CreatorCrawl dashboard"
      }
    }
  },
  "paths": {
    "/api/tiktok/profile": {
      "get": {
        "operationId": "getApiTiktokProfile",
        "tags": ["Profile"],
        "summary": "Get TikTok profile",
        "description": "Fetches a public TikTok profile by handle, including user info, stats, and recent videos.",
        "parameters": [
          {
            "name": "handle",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "TikTok handle (e.g. stoolpresidente)"
          }
        ],
        "responses": {
          "200": { "description": "TikTok profile data including user info, stats, and recent videos" },
          "400": { "description": "Missing or invalid handle" },
          "401": { "description": "Unauthorized — missing or invalid API key" },
          "502": { "description": "Upstream API error — TikTok returned an error, retry the request" }
        }
      }
    },
    "/api/tiktok/profile/videos": {
      "get": {
        "operationId": "getApiTiktokProfileVideos",
        "tags": ["Profile"],
        "summary": "Get profile videos",
        "description": "Extract videos from a TikTok profile with sorting and pagination support.",
        "parameters": [
          {
            "name": "handle",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "TikTok handle (e.g. stoolpresidente)"
          },
          {
            "name": "user_id",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "User ID for faster response times"
          },
          {
            "name": "sort_by",
            "in": "query",
            "required": false,
            "schema": { "type": "number", "enum": [0, 1] },
            "description": "Sort order. 0 = newest first (default), 1 = most popular first"
          },
          {
            "name": "max_cursor",
            "in": "query",
            "required": false,
            "schema": { "type": "number" },
            "description": "Pagination cursor from previous response"
          },
          {
            "name": "region",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Proxy region. Use 2 letter country codes (US, GB, FR, etc.)"
          },
          {
            "name": "trim",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean" },
            "description": "Set to true to get a trimmed response with fewer fields"
          }
        ],
        "responses": {
          "200": { "description": "List of videos from the profile with pagination cursor" },
          "400": { "description": "Missing or invalid handle" },
          "401": { "description": "Unauthorized — missing or invalid API key" },
          "502": { "description": "Upstream API error — TikTok returned an error, retry the request" }
        }
      }
    },
    "/api/tiktok/user/audience": {
      "get": {
        "operationId": "getApiTiktokUserAudience",
        "tags": ["Profile"],
        "summary": "Get user audience demographics",
        "description": "Get the audience demographics of a TikTok user. Returns audience country distribution. Costs 26 credits per request.",
        "parameters": [
          {
            "name": "handle",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "TikTok handle (e.g. shakira)"
          }
        ],
        "responses": {
          "200": { "description": "Audience demographics with country distribution" },
          "400": { "description": "Missing or invalid handle" },
          "401": { "description": "Unauthorized — missing or invalid API key" },
          "502": { "description": "Upstream API error — TikTok returned an error, retry the request" }
        }
      }
    },
    "/api/tiktok/user/followers": {
      "get": {
        "operationId": "getApiTiktokUserFollowers",
        "tags": ["Profile"],
        "summary": "Get user followers",
        "description": "Scrapes followers of a TikTok account. Supports pagination via min_time. Provide either handle or user_id.",
        "parameters": [
          {
            "name": "handle",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "TikTok handle (e.g. stoolpresidente)"
          },
          {
            "name": "user_id",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "User ID for faster response times"
          },
          {
            "name": "min_time",
            "in": "query",
            "required": false,
            "schema": { "type": "number" },
            "description": "Pagination cursor from previous response"
          },
          {
            "name": "trim",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean" },
            "description": "Set to true to get a trimmed response"
          }
        ],
        "responses": {
          "200": { "description": "Follower list with pagination cursor" },
          "400": { "description": "Missing handle or user_id" },
          "401": { "description": "Unauthorized — missing or invalid API key" },
          "502": { "description": "Upstream API error — TikTok returned an error, retry the request" }
        }
      }
    },
