    "/api/tiktok/video": {
      "get": {
        "operationId": "getApiTiktokVideo",
        "tags": ["Video"],
        "summary": "Get video info",
        "description": "Scrapes data from a TikTok video including author, statistics, video URLs, and more.",
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "TikTok video URL"
          },
          {
            "name": "get_transcript",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Set to true to include the video transcript"
          },
          {
            "name": "region",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Proxy region. Use 2 letter country codes (US, GB, FR, PH, etc.)"
          },
          {
            "name": "trim",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Set to true to get a trimmed response"
          }
        ],
        "responses": {
          "200": { "description": "Video data including author, stats, and download URLs" },
          "400": { "description": "Missing or invalid URL" },
          "401": { "description": "Unauthorized — missing or invalid API key" },
          "502": { "description": "Upstream API error — TikTok returned an error, retry the request" }
        }
      }
    },
